# ── Variables de entorno ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Documentos legales (no subir PDFs por derechos de autor) ─────────────────
legal_docs/*.pdf

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
env/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── SSL / Certificados ────────────────────────────────────────────────────────
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key

# ── Modelos de ML (pesados, se descargan al hacer deploy) ────────────────────
.cache/
models/
*.bin
*.safetensors

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
